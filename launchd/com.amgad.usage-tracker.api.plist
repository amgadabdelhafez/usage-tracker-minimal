<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.amgad.usage-tracker.api</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-c</string>
    <string>[ -f /Users/amgad/dev_projects/usage-tracker-minimal/.env ] &amp;&amp; source /Users/amgad/dev_projects/usage-tracker-minimal/.env; exec /opt/homebrew/bin/uvicorn src.api:app --host 127.0.0.1 --port 8000</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>WorkingDirectory</key>
  <string>/Users/amgad/dev_projects/usage-tracker-minimal</string>

  <key>StandardOutPath</key>
  <string>/Users/amgad/.usage-tracker/logs/api.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/amgad/.usage-tracker/logs/api.err.log</string>
</dict>
</plist>
